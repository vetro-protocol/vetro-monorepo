{
  "extends": ["bloq", "prettier"],
  "ignorePatterns": [
    "api/.wrangler/**/*",
    "internal-dashboard/dist/**/*",
    "subgraph/**/*",
    "web/dist/**/*",
    "web/storybook-static/**/*"
  ],
  "overrides": [
    {
      "excludedFiles": ["internal-dashboard/dist/**/*", "web/dist/**/*"],
      "extends": ["bloq/esm", "bloq/typescript", "prettier"],
      "files": [
        "*.{js,mjs}",
        "api/**/*.ts",
        "internal-dashboard/**/*.{js,ts,tsx}",
        "packages/**/*.{js,ts,tsx}",
        "web/**/*.{js,ts,tsx}"
      ]
    },
    {
      "extends": ["bloq/markdown"],
      "files": ["*.md"],
      "rules": {
        "markdownlint/md024": "off"
      }
    },
    {
      "extends": ["bloq/markdown"],
      "files": [".github/pull_request_template.md"],
      "rules": {
        "markdownlint/md041": "off"
      }
    },
    {
      "extends": ["bloq/typescript", "prettier"],
      "files": ["*.d.ts"]
    },
    {
      "excludedFiles": ["api/tests/*.ts"],
      "extends": ["bloq/typescript", "bloq/vitest"],
      "files": ["*.{spec,test}.{js,ts}"]
    },
    {
      "files": ["web/stories/**/*.{js,ts,tsx}"],
      "rules": {
        "no-alert": "off"
      }
    },
    {
      "files": ["web/e2e/**/*.ts"],
      "rules": {
        "@vitest/require-hook": "off"
      }
    },
    {
      "files": ["packages/mock-wallet/**/*.ts"],
      "rules": {
        "camelcase": ["warn", { "allow": ["^eth_", "^personal_", "^wallet_"] }]
      }
    },
    {
      "files": ["packages/**/*.{js,ts,tsx}"],
      "rules": {
        "complexity": ["warn", { "max": 20 }]
      }
    },
    {
      "files": ["api/**/*.ts", "web/scripts/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "root": true
}
