{
  "extends": ["bloq", "prettier"],
  "ignorePatterns": [
    "api/.wrangler/**/*",
    "landing/.wrangler/**/*",
    "web/dist/**/*",
    "web/storybook-static/**/*"
  ],
  "overrides": [
    {
      "excludedFiles": ["subgraph/generated/**/*", "web/dist/**/*"],
      "extends": ["bloq/esm", "bloq/typescript", "prettier"],
      "files": [
        "*.{js,mjs}",
        "api/**/*.ts",
        "landing/**/*.ts",
        "packages/**/*.{js,ts,tsx}",
        "subgraph/**/*.ts",
        "web/**/*.{js,ts,tsx}"
      ]
    },
    {
      "extends": ["bloq/markdown"],
      "files": ["*.md"],
      "rules": {
        "markdownlint/md024": "off"
      }
    },
    {
      "extends": ["bloq/markdown"],
      "files": [".github/pull_request_template.md"],
      "rules": {
        "markdownlint/md041": "off"
      }
    },
    {
      "extends": ["bloq/typescript", "prettier"],
      "files": ["*.d.ts"]
    },
    {
      "excludedFiles": ["api/tests/*.ts", "subgraph/tests/*.ts"],
      "extends": ["bloq/typescript", "bloq/vitest"],
      "files": ["*.{spec,test}.{js,ts}"]
    },
    {
      "files": ["web/stories/**/*.{js,ts,tsx}"],
      "rules": {
        "no-alert": "off"
      }
    },
    {
      "files": ["landing/**/*.ts", "packages/**/*.{js,ts,tsx}"],
      "rules": {
        "complexity": ["warn", { "max": 20 }]
      }
    },
    {
      "files": ["api/**/*.ts", "landing/**/*.ts", "web/scripts/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["landing/public/**/*.js"],
      "globals": {
        "document": "readonly",
        "fetch": "readonly",
        "setTimeout": "readonly"
      }
    }
  ],
  "root": true
}
